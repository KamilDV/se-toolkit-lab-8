{
  "version": 1,
  "jobs": [
    {
      "id": "health-check-001",
      "name": "System Health Check",
      "schedule": "*/15 * * * *",
      "description": "Check for backend errors every 15 minutes and post summary",
      "enabled": true,
      "created_at": "2026-04-01T23:30:00Z",
      "last_run": null,
      "next_run": "2026-04-02T00:00:00Z",
      "actions": [
        {
          "tool": "logs_error_count",
          "params": {"hours": 1, "service": "*"}
        },
        {
          "tool": "logs_search",
          "params": {"query": "level:error", "limit": 5}
        }
      ]
    }
  ]
}
